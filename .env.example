# Copy to .env and fill in your keys.

# Required — Google Lens via RapidAPI
RAPID_API_KEY=

# Recommended — image hosting for Lens
IMGBB_API_KEY=

# Listing draft — at least one AI key
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — direct API4AI portal (otherwise RapidAPI is used for try-on)
API4AI_API_KEY=

# Optional — boost TPT inventory in Lens results (off by default)
# TPT_INVENTORY_BOOST=1
# TPT_INVENTORY_DOMAINS=timepiecetradingllc.com,timepiecetrading.com
